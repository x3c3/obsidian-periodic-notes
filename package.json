{
  "name": "periodic-notes",
  "version": "1.1.1",
  "description": "Create and manage daily, weekly, monthly, quarterly, and yearly notes",
  "main": "main.js",
  "author": "Mark Ayers (originally by Liam Cain)",
  "license": "MIT",
  "scripts": {
    "audit": "bun audit --audit-level=critical",
    "dev": "vite build --watch",
    "build": "bun run check && vite build",
    "check": "bun run typecheck && biome check . && svelte-check",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "validate": "bun run scripts/validate-plugin.ts",
    "version": "bun run version-bump.ts",
    "test": "bun test",
    "deploy": "cp main.js manifest.json styles.css ~/source/philoserf/notes/.obsidian/plugins/periodic-notes/"
  },
  "dependencies": {
    "svelte": "^5.53.10"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tsconfig/svelte": "^5.0.8",
    "@types/bun": "^1.3.10",
    "@types/node": "^25.4.0",
    "moment": "^2.30.1",
    "obsidian": "^1.12.3",
    "sass": "^1.98.0",
    "svelte-check": "^4.4.5",
    "svelte-writable-derived": "^3.1.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
